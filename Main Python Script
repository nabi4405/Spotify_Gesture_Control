def send_to_mcu(label: str):
    try:
        Bridge.call("set_pixel_state", label)
        print(f"[bridge] set_pixel_state -> {label}")
    except Exception as e:
        print(f"[bridge] failed to notify MCU: {e}")


def send_to_spotify(label: str):
    def _api_call():
        try:
            if label == "Play":
                sp.start_playback()
            elif label == "Pause":
                sp.pause_playback()
            elif label == "Next_Track":
                sp.next_track()
            elif label == "Previous_Track":
                sp.previous_track()
            print(f"[spotify] successfully sent -> {label}")
        except SpotifyException as e:
            if e.http_status == 404:
                print(
                    "[spotify] error: no active device found. Open Spotify on your phone and play a track first!"
                )
            elif e.http_status == 403:
                print(
                    "[spotify] error: permission denied. Check Premium status and scopes."
                )
            else:
                print(f"[spotify] API error ({e.http_status}): {e.msg}")
        except Exception as e:
            print(f"[spotify] unexpected network error: {e}")

    threading.Thread(target=_api_call, daemon=True).start()


def handle_gesture(label: str):
    global _last_trigger_time
    now = time.time()
    if now - _last_trigger_time < ACTION_COOLDOWN_SEC:
        return
    _last_trigger_time = now

    print(f"[gesture] confirmed '{label}'")
    send_to_mcu(label)
    send_to_spotify(label)


def send_detections_to_ui(detections: dict):
    best_label = None
    best_confidence = 0.0

    for label, values in detections.items():
        for value in values:
            conf = value.get("confidence", 0.0)
            if conf >= CONFIDENCE_THRESHOLD and conf > best_confidence:
                best_confidence = conf
                best_label = label

    if best_label is not None:
        handle_gesture(best_label)


detection_stream.on_detect_all(send_detections_to_ui)

App.run()
